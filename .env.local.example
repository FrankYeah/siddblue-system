# ─────────────────────────────────────────────────────────────
#  西打藍好內容有限公司 — 報價系統環境變數
#  複製此檔為 .env.local 後填入實際值
#  取得方式：Vercel Dashboard → Storage → 建立 KV (Upstash) → .env.local 分頁
# ─────────────────────────────────────────────────────────────

# Vercel KV (Upstash Redis) — @vercel/kv 讀寫所需
KV_URL="rediss://default:xxxxxxxx@xxxx.upstash.io:6379"
KV_REST_API_URL="https://xxxx.upstash.io"
KV_REST_API_TOKEN="AxxxxxxxxxxxxxxxxxxxxxxxxAAIncDE..."
KV_REST_API_READ_ONLY_TOKEN="ArxxxxxxxxxxxxxxxxxxxxxxxxAAIgcDE..."

# 後台 /admin 存取密碼 (簡易保護，避免報價單被任意編輯)
# 在瀏覽器輸入密碼後會存於 cookie；未設定則後台不設密碼保護
ADMIN_PASSWORD="請設定一組後台密碼"

# 對外網址 (用於產生分享連結；本機可留空自動偵測)
NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# ─────────────────────────────────────────────────────────────
#  AI — 內容矩陣引擎 (Content Matrix Engine)
#  「寫作靈感庫 → 長文電子報」卡片一鍵生成短影音腳本所需
#  取得方式：https://platform.openai.com → API Keys
#  未設定時矩陣生成功能會回覆明確錯誤提示，其餘功能不受影響
# ─────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."

# ─────────────────────────────────────────────────────────────
#  📦 資料備份 (Backup & Export) — 每日自動快照
#  設定後，Vercel Cron 呼叫 GET /api/backup/snapshot 時會自動帶上
#  `Authorization: Bearer <CRON_SECRET>`，用來驗證這是排程觸發（而非外部亂打）。
#  未設定也不影響後台「立即備份」手動按鈕（走登入 cookie 驗證）。
#  請在 Vercel Dashboard → Project → Settings → Environment Variables 設定，
#  值可用任意隨機字串，例如：openssl rand -hex 32
# ─────────────────────────────────────────────────────────────
CRON_SECRET="請設定一組隨機字串"

# ─────────────────────────────────────────────────────────────
#  🖼️ 知識庫圖片上傳 (Vercel Blob)
#  取得方式：Vercel Dashboard → Storage → Create Database → Blob
#            建立後於專案 Storage 頁籤「Connect」→ .env.local 分頁複製
#  未設定時「上傳圖片」按鈕會回覆明確錯誤提示，其餘功能不受影響
# ─────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
